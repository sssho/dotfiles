  "demo-binread": {
    "prefix": "demo-binread",
    "body": [
      "from functools import partial",
      "",
      "def binstream(path):",
      "    with open(path, 'rb') as ifile:",
      "        chunk_byte = 4",
      "        read_chunk = partial(ifile.read, chunk_byte)",
      "",
      "        for data in iter(read_chunk, b''):",
      "            yield data",
      "${0}"
    ],
    "description": "read bindata from file"
  },
