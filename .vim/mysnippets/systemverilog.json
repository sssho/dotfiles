{
  "bind": {
    "prefix": "bind",
    "body": [
      "bind ${1:dst} ${2:src} ${3:inst}(${0});"
    ],
    "description": "bind"
  },
  "inc": {
    "prefix": "inc",
    "body": [
      "\\`include \"${0}\""
    ],
    "description": "include"
  },
  "def": {
    "prefix": "def",
    "body": [
      "\\`define ${0}"
    ],
    "description": "define"
  },
  "ifd": {
    "prefix": "ifd",
    "body": [
      "\\`ifdef ${0}",
      "\\`endif"
    ],
    "description": "ifdef .. endif"
  },
  "guard": {
    "prefix": "guard",
    "body": [
      "\\`ifndef ${1:name}",
      "\\`define $1",
      "${0}",
      "\\`endif"
    ],
    "description": "include guard"
  },
  "ini": {
    "prefix": "ini",
    "body": [
      "initial begin",
      "    ${0}",
      "end"
    ],
    "description": "initial begin .. end"
  },
  "pack": {
    "prefix": "pack",
    "body": [
      "package ${1:name};",
      "    ${0}",
      "endpackage"
    ],
    "description": "package ... endpackage"
  },
  "modu": {
    "prefix": "modu",
    "body": [
      "module ${1:name};",
      "    ${0}",
      "endmodule"
    ],
    "description": "module ... endmodule"
  },
  "always": {
    "prefix": "always",
    "body": [
      "always @(posedge clk) begin",
      "    ${0}",
      "end"
    ],
    "description": "always ... end"
  },
  "forever": {
    "prefix": "forever",
    "body": [
      "forever begin",
      "    ${0}",
      "end"
    ],
    "description": "forever ... end"
  },
  "case": {
    "prefix": "case",
    "body": [
      "case (${1:cond})",
      "    /*cond*/:",
      "    default:",
      "endcase"
    ],
    "description": "case ... endcase"
  },
  "inte": {
    "prefix": "inte",
    "body": [
      "interface ${1:name};",
      "    ${0}",
      "endinterface"
    ],
    "description": "interface ... endinterface"
  },
  "gen": {
    "prefix": "gen",
    "body": [
      "generate",
      "    ${0}",
      "endgenerate"
    ],
    "description": "generate ... endgenerate"
  },
  "fun": {
    "prefix": "fun",
    "body": [
      "function automatic ${1:void} ${2:funcname}(${3});",
      "    ${0}",
      "endfunction"
    ],
    "description": "function ... endfunction"
  },
  "fork": {
    "prefix": "fork",
    "body": [
      "fork",
      "    ${0}",
      "join"
    ],
    "description": "fork .. join"
  },
  "forka": {
    "prefix": "forka",
    "body": [
      "fork",
      "    ${0}",
      "join_any"
    ],
    "description": "fork .. join_any"
  },
  "forkn": {
    "prefix": "forkn",
    "body": [
      "fork",
      "    ${0}",
      "join_none"
    ],
    "description": "fork .. join_none"
  },
  "demo-forkw": {
    "prefix": "demo-forkw",
    "body": [
      "task do_test;",
      "    fork",
      "        do_something0();",
      "        do_something1();",
      "    join_any",
      "    fork",
      "        do_something2();",
      "        do_something3();",
      "    join_none",
      "    wait fork; // block until 0, 1, 2, 3 complete",
      "endtask"
    ],
    "description": "wait fork example"
  },
  "demo-forkd": {
    "prefix": "demo-forkd",
    "body": [
      "task get_first;",
      "    fork",
      "        do_something0();",
      "        do_something1();",
      "        do_something2();",
      "    join_any",
      "    disable fork;",
      "endtask"
    ],
    "description": "disable fork example"
  },
  "stru": {
    "prefix": "stru",
    "body": [
      "typedef struct {",
      "    ${0}",
      "} ${1:typename};"
    ],
    "description": "struct"
  },
  "enum": {
    "prefix": "enum",
    "body": [
      "typedef enum int {",
      "    ${0}",
      "} ${1:typename};"
    ],
    "description": "enum"
  },
  "rep": {
    "prefix": "rep",
    "body": [
      "repeat(${1:10}) begin",
      "    ${0}",
      "end"
    ],
    "description": "repeat"
  },
  "for": {
    "prefix": "for",
    "body": [
      "for (int ${1:i} = ${2:0}; $1 < ${3}; $1++) begin",
      "    ${0}",
      "end"
    ],
    "description": "for loop"
  },
  "fore": {
    "prefix": "fore",
    "body": [
      "foreach (${1:array}[${2:i}]) begin",
      "    ${0}  // $1[$2]",
      "end"
    ],
    "description": "foreach"
  },
  "if": {
    "prefix": "if",
    "body": [
      "if (${1:cond}) begin",
      "    ${0}",
      "end"
    ],
    "description": "if"
  },
  "ife": {
    "prefix": "ife",
    "body": [
      "if (${1:cond}) begin",
      "    ${0}",
      "end else begin",
      "end"
    ],
    "description": "if else"
  },
  "pos": {
    "prefix": "pos",
    "body": [
      "@(posedge ${1:clk})${0}"
    ],
    "description": "posedge"
  },
  "con": {
    "prefix": "con",
    "body": [
      "constraint ${1:constname} {",
      "    ${0}",
      "}"
    ],
    "description": "constraint"
  },
  "pro": {
    "prefix": "pro",
    "body": [
      "property ${1:name};",
      "    ${0}",
      "endproperty"
    ],
    "description": "property .. endproperty"
  },
  "demo-property": {
    "prefix": "demo-property",
    "body": [
      "property sample;",
      "    @(posedge clk disable iff reset_n)",
      "        $rose(valid) |=> ack;",
      "endproperty"
    ],
    "description": "property example"
  },
  "seq": {
    "prefix": "seq",
    "body": [
      "sequence ${1:name};",
      "    ${0}",
      "endsequence"
    ],
    "description": "sequence .. endsequence"
  },
  "demo-sequence": {
    "prefix": "demo-sequence",
    "body": [
      "sequence s(x, y);",
      "    x ##1 y;",
      "endsequence"
    ],
    "description": "sequence example"
  },
  "void": {
    "prefix": "void",
    "body": [
      "void'(${1:func_call})"
    ],
    "description": "void`"
  },
  "cast": {
    "prefix": "cast",
    "body": [
      "$cast(${1:dst}, ${2:src});"
    ],
    "description": "$cast"
  },
  "disp": {
    "prefix": "disp",
    "body": [
      "$display(\"${0}\");"
    ],
    "description": "$display"
  },
  "sfor": {
    "prefix": "sfor",
    "body": [
      "$sformatf(\"${0}\", )"
    ],
    "description": "$sformatf"
  },
  "time": {
    "prefix": "time",
    "body": [
      "$realtime"
    ],
    "description": "$realtime"
  },
  "fat": {
    "prefix": "fat",
    "body": [
      "$fatal(${0});"
    ],
    "description": "$fatal"
  },
  "fin": {
    "prefix": "fin",
    "body": [
      "$finish(${0});"
    ],
    "description": "$finish"
  },
  "demo-filewrite": {
    "prefix": "demo-filewrite",
    "body": [
      "int ofp;",
      "",
      "ofp = $fopen(\"outfile.csv\", \"w\");",
      "$fdisplay(ofp, \"%d, %d, %d\", 1, 2, 3);",
      "$fclose(ofp);"
    ],
    "description": "write somethng to file"
  }
}
