set nocompatible

if has('vim_starting')
  if !exists($XDG_DATA_HOME)
    let $XDG_DATA_HOME = $HOME . '/.local/share'
  endif
  if !isdirectory($XDG_DATA_HOME . '/vim')
    call mkdir($XDG_DATA_HOME . '/vim', "p")
  endif
endif

if filereadable(expand('$HOME/.vim/vimrc_local.vim'))
  source $HOME/.vim/vimrc_local.vim
endif

set statusline=%m%f%r\ [%{&filetype}:%{&fileencoding}:%{&fileformat}]\ %l/%L\ %c\ %p%%\ %{strftime('%H:%M')}

command! ReloadVimrc execute 'source $MYVIMRC' | echo "Reloaded: " . expand('$MYVIMRC')

function! s:SetViminfo() abort
  if !exists($XDG_CACHE_HOME)
    let $XDG_CACHE_HOME = $HOME . '/.cache'
  endif
  if !isdirectory($XDG_CACHE_HOME . '/vim')
    call mkdir($XDG_CACHE_HOME . '/vim', "p")
  endif
  set viminfo+=n$XDG_CACHE_HOME/vim/viminfo
endfunction

if has('vim_starting')
  call s:SetViminfo()
endif

" [core.filetypes]
filetype plugin indent on

" [editor.ui]
set number
set relativenumber
set showcmd
set showmatch
set list

" [editor.search]
set ignorecase
set smartcase
set hlsearch

" [editor.edit]
set expandtab
set tabstop=4
set shiftwidth=4
set hidden
set smartindent

" [editor.backup]
set nowritebackup
set nobackup
set noswapfile

" [editor.clipboard]
set clipboard+=unnamed

" [editor.ux]
set ttimeoutlen=10
set t_vb=
set novisualbell

" [syntax]
syntax enable

" [leader]
let mapleader = "\<Space>"

" [mappings.normal]
nnoremap <Leader>w :w<CR>
nnoremap <Leader>p "+p<CR>
nnoremap <Leader>P "+P<CR>

" [mappings.insert]
imap <silent> jj <ESC>

" [mappings.visual]
vnoremap <silent> y y`]
vnoremap <silent> p p`]

" [autocmds.directory]
function! s:ChangeCurrentDirectory()
  let l:dir = expand("%:p:h")
  if isdirectory(fnamemodify(l:dir, ":p"))
    execute printf('lcd `=%s`', string(fnamemodify(l:dir, ":p")))
  endif
endfunction
autocmd BufEnter * call s:ChangeCurrentDirectory()

" [source.svsource]
function! s:SourceMyCompSource()
  let l:svsource = expand('~/.vim/mycompsource/svsource.vim')
  if filereadable(svsource)
    execute 'source' svsource
  endif
endfunction
call s:SourceMyCompSource()

function! s:has_plugin(name) abort
  return isdirectory(expand($XDG_DATA_HOME . '/vim/plugged/' . a:name))
endfunction

